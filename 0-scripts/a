#!/bin/bash
# Author: Roy Wiseman 2026-01
# Universal Application Package Manager Wrapper

RED='\e[31m'
NC='\e[0m'

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" &> /dev/null && pwd)"

command_exists() {
    command -v "$1" &> /dev/null
}

# Define Managers and their helper script names
# Logic: Order matters. Brew is checked first for Mac/Linux hybrid environments.
if command_exists brew; then
    HELPER="brew-a"
elif command_exists apt; then
    HELPER="apt-a"
elif command_exists apk; then
    HELPER="apk-a"
elif command_exists dnf; then
    HELPER="dnf-a"
elif command_exists yum; then
    HELPER="yum-a"
elif command_exists zypper; then
    HELPER="zypper-a"
elif command_exists pacman; then
    HELPER="pacman-a"
else
    echo -e "${RED}Error: No supported package manager found.${NC}"
    exit 1
fi

HELPER_PATH="${SCRIPT_DIR}/0-a-helpers/${HELPER}"

if [ -x "$HELPER_PATH" ]; then
    exec "$HELPER_PATH" "$@"
else
    echo -e "${RED}Error: Helper script not found or executable at '$HELPER_PATH'.${NC}"
    exit 1
fi
